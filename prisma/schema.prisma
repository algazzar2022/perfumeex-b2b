generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(COMPANY_OWNER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company?
  reviews       Review[]
}

enum Role {
  SUPER_ADMIN
  COMPANY_OWNER
}

model Company {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  nameAr      String
  nameEn      String
  slug        String   @unique
  descriptionAr String? @db.LongText
  descriptionEn String? @db.LongText
  
  logo        String? @db.LongText
  coverImage  String? @db.LongText
  catalogPdf  String? @db.LongText
  
  category      String?
  countryAr     String?
  countryEn     String?
  governorateAr String?
  governorateEn String?
  cityAr        String?
  cityEn        String?
  addressAr     String?
  addressEn     String?
  
  whatsapp    String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  twitter     String?
  
  isVerified  Boolean  @default(false)
  isFeatured  Boolean  @default(false)
  isSponsor   Boolean  @default(false)
  status      CompanyStatus @default(PENDING)
  
  profileViews  Int @default(0)
  contactClicks Int @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  branches    Branch[]
  products    Product[]
  galleries   Gallery[]
  categories  Category[] @relation("CompanyCategories")
  reviews     Review[]
  
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
  
  order            Int       @default(0)
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameAr      String
  nameEn      String
  image       String?
  companies   Company[] @relation("CompanyCategories")
  order       Int       @default(0)
}

model Branch {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  nameAr      String
  nameEn      String
  addressAr   String?
  addressEn   String?
  
  countryAr     String?
  countryEn     String?
  governorateAr String?
  governorateEn String?
  cityAr        String?
  cityEn        String?
  phone       String?
  latitude    Float?
  longitude   Float?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model City {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  slug        String   @unique
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId  String?
  
  nameAr      String
  nameEn      String
  descriptionAr String? @db.LongText
  descriptionEn String? @db.LongText
  
  price       Float?
  image       String? @db.LongText
  
  stockStatus String? @default("IN_STOCK")
  salesType   String? @default("WHOLESALE")
  
  status      ProductStatus @default(PENDING)
  order       Int       @default(0)
  isFeatured  Boolean   @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

model Gallery {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  url         String   @db.LongText
  type        GalleryType @default(IMAGE)
  createdAt   DateTime @default(now())
}

enum GalleryType {
  IMAGE
  VIDEO
}

model Sponsor {
  id          String   @id @default(cuid())
  nameAr      String
  nameEn      String
  logo        String
  url         String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
}

model Ad {
  id          String   @id @default(cuid())
  titleAr     String
  titleEn     String
  image       String
  url         String?
  isActive    Boolean  @default(true)
  position    AdPosition @default(HOMEPAGE)
}

enum AdPosition {
  HOMEPAGE
  CATEGORY_PAGE
  SIDEBAR
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  comment     String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  
  @@unique([userId, companyId])
}

model Analytics {
  id          String   @id @default(cuid())
  companyId   String?
  pageView    Int      @default(0)
  whatsappClick Int    @default(0)
  date        DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  
  senderId    String
  sender      Company  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  receiverId  String
  receiver    Company  @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  
  content     String   @db.LongText
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  titleAr     String
  titleEn     String
  image       String   @db.LongText
  date        DateTime
  locationAr  String
  locationEn  String
  
  registrations EventRegistration[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventRegistration {
  id              String   @id @default(cuid())
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  name            String
  age             Int
  brandName       String
  location        String
  phone           String
  whatsapp        String
  experienceYears Int
  
  createdAt       DateTime @default(now())
}
